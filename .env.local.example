# Subpath for hosting under /ccs — leave blank for local dev, set to /ccs in production
NEXT_PUBLIC_BASE_PATH=

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google OAuth (Optional here if using Supabase Auth, you usually put these in the Supabase Dashboard, not the Next.js env, but we might need them if we hit Gmail API server-side)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
